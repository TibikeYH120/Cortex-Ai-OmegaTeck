# ── CORTEX AI — Railway Environment Variables ─────────────────────────────────
#
# Set these in your Railway project:  Dashboard → Service → Variables
#
# 1. Add a PostgreSQL service in Railway; DATABASE_URL is injected automatically.
#    If using an external DB (Neon, Supabase, etc.), paste the connection string below.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# 2. Anthropic (Claude) — use the official API endpoint + your API key.
#    Get your key at: https://console.anthropic.com/settings/keys
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. Google AI (Gemini) — used for image generation.
#    Get your key at: https://aistudio.google.com/app/apikey
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_INTEGRATIONS_GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4. Session secret — any long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-string

# 5. NODE_ENV — set to production on Railway (Railway sets this automatically via Dockerfile ENV)
NODE_ENV=production
