# ── CORTEX AI — Environment Variables ─────────────────────────────────────────
#
# For Replit: set these in Secrets (Tools → Secrets)
# For Railway: Dashboard → Service → Variables
# For Cloudflare Pages/Workers: not applicable (this is a Node.js app)
#
# ── Database ───────────────────────────────────────────────────────────────────
# Add a PostgreSQL service; DATABASE_URL is injected automatically on Railway.
# On Replit, use the built-in PostgreSQL integration.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI Keys ────────────────────────────────────────────────────────────────────
# Anthropic (Claude) — https://console.anthropic.com/settings/keys
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI (Gemini) — https://aistudio.google.com/app/apikey
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_INTEGRATIONS_GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Session ────────────────────────────────────────────────────────────────────
# Any long random string — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── Node environment ───────────────────────────────────────────────────────────
NODE_ENV=production

# ── Frontend API URL (optional) ────────────────────────────────────────────────
# Leave empty to use relative /api/... paths (best for same-origin deploys on Replit).
# Set to your full domain if the frontend and API are on different origins, e.g.:
#   VITE_API_URL=https://cortex-ai.yourdomain.com
# This is useful when pointing a Cloudflare custom domain at the Replit deployment.
VITE_API_URL=

# ── Cloudflare notes ───────────────────────────────────────────────────────────
# 1. Point your Cloudflare DNS A/CNAME record to your Replit deployment URL.
# 2. In Cloudflare SSL/TLS, set mode to "Full" (not "Full Strict") since Replit
#    uses a self-signed cert internally.
# 3. The server already handles CF-Connecting-IP for real visitor IPs.
# 4. trust proxy is set to true — correct for Cloudflare's multi-hop setup.
# 5. No extra Cloudflare Workers or Pages config needed; the app is self-contained.
